# ============================================================
#  CARNICERÍA EL FUNDO — Variables de Entorno
# ============================================================

# --- APP ---
NODE_ENV=development
APP_NAME="Carniceria El Fundo"
APP_VERSION=1.0.0

# --- API ---
API_PORT=3001
API_URL=http://localhost:3001
API_SECRET=change_this_secret_min_32_chars_long

# --- JWT ---
JWT_SECRET=change_this_jwt_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- DATABASE CLOUD (PostgreSQL) ---
DATABASE_URL=postgresql://elfundo:password@localhost:5432/elfundo_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=elfundo_db
DATABASE_USER=elfundo
DATABASE_PASS=change_this_password

# --- REDIS ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- POS LOCAL (SQLite) ---
POS_DB_PATH=./data/pos.db
POS_SYNC_INTERVAL_MS=300000
POS_WEBSOCKET_URL=ws://localhost:3001

# --- WEB (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- TRANSBANK (WebpayPlus) ---
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
TRANSBANK_ENV=integration
# En producción usar: TRANSBANK_ENV=production

# --- MERCADO PAGO ---
MP_ACCESS_TOKEN=TEST-your-access-token
MP_PUBLIC_KEY=TEST-your-public-key
MP_WEBHOOK_SECRET=your-webhook-secret

# --- EMAILS (Resend) ---
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@carniceriaelfundo.cl

# --- STORAGE (Cloudflare R2 / AWS S3) ---
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_BUCKET=elfundo-assets
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_PUBLIC_URL=https://assets.carniceriaelfundo.cl

# --- GOOGLE MAPS (geocoding) ---
GOOGLE_MAPS_API_KEY=your-google-maps-key

# --- SENTRY (errores) ---
SENTRY_DSN=https://your-sentry-dsn

# --- LOGS ---
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

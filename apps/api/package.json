{
  "name": "@elfundo/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "start": "node dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config jest-e2e.json",
    "generate": "prisma generate",
    "db:migrate": "prisma migrate dev",

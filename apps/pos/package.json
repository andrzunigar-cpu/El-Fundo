{
  "name": "@elfundo/pos",
  "version": "1.0.0",
  "private": true,
  "description": "POS Local Carnicería El Fundo — Electron",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "tsc:electron": "tsc -p electron/tsconfig.json",
    "dev:electron": "wait-on http://localhost:5173 && pnpm tsc:electron && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"vite\" \"pnpm dev:electron\"",
    "build": "vite build && pnpm tsc:electron && electron-builder",
    "build:win": "vite build && pnpm tsc:electron && electron-builder --win",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "lucide-react": "^0.378.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.0",
    "socket.io-client": "^4.7.4",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "cl.carniceriaelfundo.pos",
    "productName": "El Fundo POS",
    "copyright": "Carnicería El Fundo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "icon": "public/icon.ico",
    "npmRebuild": false,
    "win": {
      "icon": "public/icon.ico",
      "target": [
        { "target": "dir", "arch": ["x64"] }
      ]
    }
  }
}
